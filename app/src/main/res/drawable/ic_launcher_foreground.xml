<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Central sharp tactical digital Crosshair -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,24 L54,16 M54,92 L54,84 M16,54 L24,54 M84,54 L92,54"
        android:strokeWidth="3.5"
        android:strokeColor="#00ffcc"
        android:strokeLineCap="round"/>

    <!-- Concentric targeting circle brackets -->
    <path
        android:fillColor="#00000000"
        android:pathData="M 36 54 A 18 18 0 0 1 72 54"
        android:strokeWidth="2.5"
        android:strokeColor="#00ff99"
        android:strokeLineCap="round"/>
    
    <!-- Outer accent wing shields representing military/tradition mixture -->
    <path
        android:pathData="M44,48 L54,34 L64,48 L54,42 Z"
        android:strokeWidth="1">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="34"
                android:endX="54"
                android:endY="48"
                android:type="linear">
                <item android:offset="0" android:color="#00ff99"/>
                <item android:offset="1" android:color="#00ffcc"/>
            </gradient>
        </aapt:attr>
    </path>

    <path
        android:pathData="M44,60 L54,74 L64,60 L54,66 Z"
        android:strokeWidth="1">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="74"
                android:endX="54"
                android:endY="60"
                android:type="linear">
                <item android:offset="0" android:color="#00ffcc"/>
                <item android:offset="1" android:color="#00ff99"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Central core glowing bead -->
    <path
        android:fillColor="#ffffff"
        android:pathData="M54,54m-4,0a4,4 0,1 1,8 0a4,4 0,1 1,-8 0"/>
</vector>
